---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import { excerpt } from "../../lib/excerpt";

// Published posts, newest first. Drafts are excluded from the build.
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title="Blog"
  description="My thoughts on software engineering, machine learning, robotics, math, and whatever other miscellaneous things that leak out of my brain."
>
  <section class="section container">
    <p class="eyebrow reveal">Writing</p>
    <h1 class="reveal">Blog</h1>
    <p class="lead reveal">
      My thoughts on software engineering, machine learning, robotics, math, and whatever
      other miscellaneous things that leak out of my brain.
    </p>

    {
      posts.length === 0 ? (
        <p class="text-muted" style="margin-top: 2rem">
          No posts yet — check back soon.
        </p>
      ) : (
        <div class="posts" style="margin-top: 2rem">
          {posts.map((post) => (
            <a class="card reveal post" href={`/blog/${post.id}`}>
              <time class="date text-muted" datetime={post.data.date.toISOString()}>
                {dateFmt.format(post.data.date)}
              </time>
              <h2>{post.data.title}</h2>
              <p class="blurb">{post.data.description}</p>
              <p class="excerpt">{excerpt(post.body)}</p>
              {post.data.tags.length > 0 && (
                <ul class="chips">
                  {post.data.tags.map((t) => (
                    <li class="chip">{t}</li>
                  ))}
                </ul>
              )}
              <span class="more">
                Read post <Icon name="arrow-right" size={16} />
              </span>
            </a>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  .posts {
    display: grid;
    gap: 1.25rem;
  }
  .post {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    color: var(--text);
  }
  .post:hover {
    color: var(--text);
  }
  .date {
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .post h2 {
    margin: 0;
    font-size: 1.35rem;
  }
  .blurb {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .excerpt {
    margin: 0;
    font-family: var(--font-sans);
    color: var(--text-muted);
  }
  .more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent);
  }
</style>
