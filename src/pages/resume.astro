---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";

const RESUME = "/resume.pdf";
---

<BaseLayout
  title="Resume"
  description="Eugene Zhang's résumé — education, skills, experience, and projects."
>
  <section class="section container">
    <div class="head">
      <div>
        <p class="eyebrow">Résumé</p>
        <h1>Resume</h1>
        <p class="lead">
          A snapshot of my education, skills, experience, and projects.
        </p>
      </div>
      <div class="btn-row">
        <a href={RESUME} download class="btn btn-primary">
          Download PDF <Icon name="download" size={16} />
        </a>
        <a href={RESUME} target="_blank" rel="noopener noreferrer" class="btn">
          Open in new tab <Icon name="external" size={16} />
        </a>
      </div>
    </div>

    <div class="viewer card">
      <object data={RESUME} type="application/pdf" width="100%" height="100%">
        <iframe src={RESUME} title="Eugene Zhang résumé" width="100%" height="100%"
        ></iframe>
        <p class="fallback">
          Your browser can't display the embedded PDF.
          <a href={RESUME} download>Download the résumé</a> instead.
        </p>
      </object>
    </div>
  </section>
</BaseLayout>

<style>
  .head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .head h1 {
    margin-bottom: 0.25rem;
  }
  .head .lead {
    margin: 0;
  }
  .viewer {
    padding: 0;
    overflow: hidden;
    height: min(80vh, 1100px);
  }
  .viewer object,
  .viewer iframe {
    display: block;
    border: 0;
    height: 100%;
  }
  .fallback {
    padding: 2rem;
    text-align: center;
  }
</style>
