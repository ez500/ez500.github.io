---
import BaseLayout from "../layouts/BaseLayout.astro";

const education = [
  {
    school: "Purdue University",
    place: "West Lafayette, IN, US",
    detail: "B.S. in Computer Science & Mathematics, Minor in Economics — GPA 3.9/4.0",
    dates: "Aug 2025 – est. May 2027",
    notes: [
      "Relevant coursework: ML & Data Mining, Database Systems, Intro to AI, Software Engineering",
      "John Martinson Honors College",
    ],
  },
  {
    school: "West Lafayette Jr/Sr High School",
    place: "West Lafayette, IN, US",
    detail: "High School Diploma — GPA 3.9/4.0",
    dates: "Aug 2021 – May 2025",
    notes: [
      "Academic Honors, Magna Cum Laude",
      "Many Purdue courses taken dual-credit (DS&A, Analysis of Algorithms, Real Analysis, Probability)",
    ],
  },
];

const hobbies = [
  "Tennis",
  "Pickleball",
  "Church & Worship",
  "Acoustic / Electric Guitar",
  "Piano",
  "Violin",
  "FPS Games",
];
---

<BaseLayout
  title="About Me"
  description="About Eugene Zhang — CS & Mathematics student, software developer, and lifelong learner."
>
  <section class="section container">
    <p class="eyebrow reveal">About Me</p>
    <h1 class="reveal">Hi, I'm Eugene.</h1>
    <div class="bio card reveal">
      <p>
        I am an undergraduate student at Purdue University double majoring in
        Computer Science and Mathematics, with a minor in Economics, as well as
        a part-time software developer with a strong background in applications
        programming, software engineering, and machine learning via agentic systems.
        I enjoy solving problems with unique approaches and thrive on collaboration,
        through which I develop cool software projects.
      </p>
    </div>
  </section>

  <section class="section container">
    <h2 class="reveal">Small Bio</h2>
    <p class="lead reveal">
      Although I was born in Boston, I've spent most of my childhood and life in
      West Lafayette, IN, having went to West Lafayette Schools and graduated from
      West Lafayette Jr/Sr High School. With the opportunities of higher education
      literally right next to me, I was able to take Purdue courses throughout my
      secondary schooling. Hence, I'll be able to graduate soon (yay).
    </p>
  </section>

  <section class="section container two-col">
    <h2 class="reveal">Hobbies &amp; Interests</h2>
    <p class="lead reveal">
      I got really into music early on in my life, starting with piano. I really
      believe the key to perfect pitch is hearing and participating in music when
      you're literally a toddler, so learning musical notes becomes like learning
      colors or anything else seemingly primitive to the normal adult person. That
      said, I currently play a lot of guitar (acoustic & electric, not so much bass)
      as well as piano, and a bit of violin. I play some indie, pop, rock, and
      Christian worship music (I serve at my local Chinese Alliance church).

      I also got into tennis near middle school. I've tried to keep up my routine
      with tennis at least a few times a week. My absolute favorite player is Federer,
      even though I know who the real goat probably is. Sometimes I stoop myself
      down to the level of pickleball. Sometimes.

      I guess I play FPS games. Like, Valorant, Overwatch, Apex, CSGO, etc. Obviously
      not a lot though, I got a ton of work to do so of course I don't play that much...
    </p>
  </section>
</BaseLayout>

<style>
  .bio {
    margin-top: 1rem;
    font-size: 1.1rem;
    line-height: 1.75;
  }
  .bio p {
    margin: 0;
  }
  .meta {
    margin: 0 0 0.5rem;
    font-size: 0.9rem;
  }
  .bullets {
    color: var(--text-muted);
    font-size: 0.93rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 0.5rem 0 0;
  }
  .two-col {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .lang-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .lang-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    font-weight: 600;
  }
</style>
