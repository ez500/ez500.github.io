---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { excerpt } from "../lib/excerpt";

// Latest project — first in the list (ordered by prominence / recency).
const latestProject = projects[0];

// Latest published blog post, newest first.
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latestPost = posts[0];

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout>
  <section class="section hero container">
    <p class="eyebrow reveal">Software Developer</p>
    <h1 class="reveal">
      Hi, I'm <span class="gradient-text">Eugene Zhang</span>.
    </h1>
    <p class="lead reveal">
      CS &amp; Mathematics @ Purdue University, minor in Economics. I build
      software with unique approaches — from API and fullstack applications to
      machine-learning image processing.
    </p>
    <div class="btn-row reveal">
      <a href="/about" class="btn btn-primary">
        About Me <Icon name="arrow-right" size={16} />
      </a>
      <a href="/projects" class="btn btn-primary">
        View Projects <Icon name="arrow-right" size={16} />
      </a>
      <a href="/blog" class="btn">Blog</a>
    </div>
  </section>

  <section class="section container">
    <h2 class="reveal">What I'm Working On</h2>
    <div class="grid grid-2">
      {latestProject && <ProjectCard project={latestProject} />}

      {
        latestPost && (
          <a class="card reveal post" href={`/blog/${latestPost.id}`}>
            <header class="head">
              <time
                class="date text-muted"
                datetime={latestPost.data.date.toISOString()}
              >
                {dateFmt.format(latestPost.data.date)}
              </time>
              <h3>{latestPost.data.title}</h3>
            </header>
            <p class="blurb">{latestPost.data.description}</p>
            <p class="excerpt">{excerpt(latestPost.body, 50)}</p>
            {latestPost.data.tags.length > 0 && (
              <ul class="chips">
                {latestPost.data.tags.map((t) => (
                  <li class="chip">{t}</li>
                ))}
              </ul>
            )}
            <span class="more">
              Read post <Icon name="arrow-right" size={16} />
            </span>
          </a>
        )
      }
    </div>
  </section>

<style>
  .hero {
    padding-block: clamp(3rem, 9vw, 6rem);
  }
  .hero .lead {
    margin-block: 1rem 1.75rem;
  }
  .post {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    height: 100%;
    color: var(--text);
  }
  .post:hover {
    color: var(--text);
  }
  .date {
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .post h3 {
    margin: 0;
    font-size: 1.35rem;
  }
  .post .blurb {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .post .excerpt {
    margin: 0;
    font-family: var(--font-sans);
    color: var(--text-muted);
  }
  .more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 0.25rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent);
  }
</style>
