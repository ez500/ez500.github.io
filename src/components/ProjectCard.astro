---
import Icon from "./Icon.astro";
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card reveal project">
  <header class="head">
    <time class="date text-muted">{project.date}</time>
    <h3>{project.title}</h3>
    <p class="role text-muted">{project.role}</p>
  </header>

  <p class="blurb">{project.blurb}</p>

  {
    project.bullets.length > 0 && (
      <ul class="bullets">
        {project.bullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    )
  }

  {
    project.tags.length > 0 && (
      <ul class="chips">
        {project.tags.map((t) => (
          <li class="chip">{t}</li>
        ))}
      </ul>
    )
  }

  {
    project.links.length > 0 && (
      <div class="links">
        {project.links.map((l) => (
          <a
            class="btn"
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            {l.label}
            <Icon name="external" size={16} />
          </a>
        ))}
      </div>
    )
  }
</article>

<style>
  .project {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
  }
  .date {
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .head h3 {
    margin: 0 0 0.15rem;
  }
  .role {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .blurb {
    margin: 0;
    color: var(--text);
  }
  .bullets {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.93rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .links {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding-top: 0.25rem;
  }
  .links .btn {
    padding: 0.5rem 0.9rem;
    font-size: 0.88rem;
  }
</style>
